{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IDP Transcription Response",
  "description": "LLM response for document transcription with confidence",
  "type": "object",
  "required": ["transcription", "confidence_score", "confidence_label", "model"],
  "additionalProperties": false,
  "allOf": [
    {
      "if": {
        "properties": {
          "confidence_label": {
            "enum": ["low", "medium"]
          }
        }
      },
      "then": {
        "required": ["notes"]
      }
    }
  ],
  "properties": {
    "transcription": {
      "type": "string",
      "description": "Extracted transcription in markdown format"
    },
    "confidence_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Numeric confidence in the transcription (0.0 to 1.0)"
    },
    "confidence_label": {
      "type": "string",
      "enum": ["low", "medium", "high"],
      "description": "Human-readable confidence level"
    },
    "model": {
      "type": "string",
      "description": "Model identifier used for the transcription"
    },
    "configuration": {
      "type": "string",
      "description": "Human-readable run settings, e.g. temperature=0.2"
    },
    "notes": {
      "type": "string",
      "minLength": 1,
      "description": "Model rationale for confidence score"
    }
  }
}
